price":12,"date":"2026-06-29"},"114":{"price":7.5,"date":"2026-06-22"},"129":{"price":3.5,"date":"2026-06-29"},"917":{"price":3,"date":"2026-06-29"},"1109":{"price":13.2,"date":"2026-06-29"},"1589":{"price":2.85,"date":"2026-06-29"}}},{"premise_code":962,"premise":"PASAR MINI K.KUMARAN","type":"Pasar Mini","prices":{"129":{"price":4.5,"date":"2026-06-29"},"917":{"price":3,"date":"2026-06-29"},"918":{"price":2.5,"date":"2026-06-29"},"1109":{"price":14.4,"date":"2026-06-29"},"1589":{"price":2.85,"date":"2026-06-29"}}},{"premise_code":942,"premise":"PASAR AWAM PAGOH","type":"Pasar Basah","prices":{"1":{"price":9.4,"date":"2026-07-04"},"102":{"price":10,"date":"2026-06-29"},"114":{"price":10,"date":"2026-07-02"},"1558":{"price":6,"date":"2026-07-02"}}},{"premise_code":9259,"premise":"KEDAI RUNCIT HOCK LEE LAI","type":"Kedai Runcit","prices":{"917":{"price":3,"date":"2026-06-29"},"918":{"price":2.5,"date":"2026-06-29"},"1109":{"price":13.8,"date":"2026-06-29"},"1589":{"price":2.85,"date":"2026-06-29"}}},{"premise_code":9258,"premise":"KEDAI RUNCIT GOH PENG GUAN","type":"Kedai Runcit","prices":{"917":{"price":3,"date":"2026-06-29"},"918":{"price":2.5,"date":"2026-06-29"},"1589":{"price":2.85,"date":"2026-06-29"}}}]},"local_issues":{"seat":[{"issue_bm":"Perabot Muar — kira-kira 800 kilang yang menghasilkan 55-60% eksport perabot negara — kini dihimpit tarif Trump 25% sejak 14 Oktober 2025, dijadual naik ke 30% pada 1 Januari 2027, sementara kos gaji minimum, KWSP pekerja asing dan elektrik terus naik; tiada pelan khas pun dari Putrajaya atau Johor untuk selamatkan periuk nasi Muar.","issue_en":"Muar's furniture industry — about 800 factories producing 55-60% of Malaysia's furniture exports — has been squeezed by Trump's 25% tariff since 14 October 2025, scheduled to rise to 30% on 1 January 2027, while minimum wage, foreign-worker EPF and electricity costs keep climbing; yet neither Putrajaya nor Johor has a rescue plan for Muar's rice bowl.","receipt_bm":"Sejak 14 Oktober 2025 AS mengenakan tarif 25% ke atas perabot upholsteri; kenaikan ke 30% ditangguh pada 31 Disember 2025 ke 1 Januari 2027. Muar: ~800 kilang, 55-60% eksport perabot Malaysia, 7,000-8,000 kontena sebulan (angka Persatuan Perabot Muar); AS ialah pasaran terbesar — hampir separuh eksport perabot negara (RM6.05 bilion daripada RM12.83 bilion, 2024).","receipt_en":"Since 14 October 2025 the US has imposed a 25% tariff on upholstered furniture; the rise to 30% was postponed on 31 December 2025 to 1 January 2027. Muar: ~800 factories, 55-60% of Malaysia's furniture exports, 7,000-8,000 containers a month (Muar Furniture Association figures); the US is the biggest market — nearly half of national furniture exports (RM6.05bn of RM12.83bn, 2024).","sources":["https://welcome.muarfurniture.org/en/about","https://www.supplychaindive.com/news/trump-tariffs-furniture-wood-products-oct-14/761469/","https://www.whitehouse.gov/fact-sheets/2025/12/fact-sheet-president-donald-j-trump-adjusts-imports-of-timber-lumber-and-their-derivative-products-into-the-united-states/","https://www.thestar.com.my/news/nation/2026/01/03/little-joy-for-local-furniture-players"],"verdict":"PARTLY_CONFIRMED"},{"issue_bm":"Selepas MUDA jadi pembangkang pada September 2023, kerajaan pusat tahan RM500,000 duit kebajikan Muar, batal projek yang dah diluluskan bernilai RM230,300, dan bila akhirnya beri RM200,000 pada Julai 2025, duit itu langsung tak boleh diguna untuk bantu rakyat.","issue_en":"After MUDA went into opposition in September 2023, the federal government withheld RM500,000 of Muar's welfare money, cancelled RM230,300 in already-approved projects, and when it finally released RM200,000 in July 2025, that money could not be used to help residents at all.","receipt_bm":"21 Julai 2025: Parlimen Muar terima hanya RM200,000 selepas lebih 500 hari rundingan — terhad kepada sewa pejabat dan gaji staf sahaja; pada 10 Mac 2026 Mahkamah Persekutuan benarkan rayuan Syed Saddiq mengenai RM500,000 yang ditahan dan projek RM230,300 yang dibatalkan.","receipt_en":"21 July 2025: Muar parliament received only RM200,000 after more than 500 days of negotiation — restricted to office rent and staff pay; on 10 March 2026 the Federal Court granted Syed Saddiq leave to appeal over the withheld RM500,000 and the cancelled RM230,300 projects.","sources":["https://www.freemalaysiatoday.com/category/bahasa/tempatan/2026/03/10/syed-saddiq-boleh-berhujah-di-mahkamah-berkait-peruntukan-parlimen-muar","https://www.malaysiakini.com/news/769922","https://www.freemalaysiatoday.com/category/bahasa/tempatan/2025/10/27/mahkamah-tolak-rayuan-syed-saddiq-berkait-peruntukan-parlimen-muar","https://lobakmerah.com/selepas-500-hari-berunding-syed-saddiq-dapat-peruntukkan-rm200k-untuk-muar/"],"verdict":"CONFIRMED"},{"issue_bm":"Muar asyik dilanda banjir — 2,829 mangsa dipindahkan pada Mac 2023 dan Bomba senaraikan 87 lokasi berisiko banjir di Muar — tetapi projek tebatan banjir Sungai Muar RM559 juta hanya siap Julai 2029, dan ia melindungi 22,000 penduduk Segamat, bukan bandar Muar. Siapa jaga rumah anda monsun depan?","issue_en":"Muar keeps flooding — 2,829 residents evacuated in March 2023 and Bomba lists 87 flood-risk spots in Muar — yet the RM559 million Sungai Muar mitigation project only finishes in July 2029, and it protects 22,000 Segamat residents, not Muar town. Who protects your house next monsoon?","receipt_bm":"The Star, 1 Mei 2026: RTB Sungai Muar Fasa 3 Pakej 1 (RM559 juta, 25km) baru melepasi 35% siap, dijangka siap Julai 2029 — manfaatnya untuk 22,000 penduduk Segamat. Sinar Harian, 3 Mac 2023: 2,829 mangsa banjir di daerah Muar, 33,149 di seluruh Johor.","receipt_en":"The Star, 1 May 2026: Sungai Muar flood mitigation Phase 3 Package 1 (RM559m, 25km) just over 35% complete, due July 2029 — beneficiaries are 22,000 Segamat residents. Sinar Harian, 3 Mar 2023: 2,829 flood victims in Muar district, 33,149 statewide.","sources":["https://www.thestar.com.my/news/nation/2026/05/01/phase-3-of-sg-muar-flood-mitigation-project-expected-to-be-completed-by-july-2029","https://www.sinarharian.com.my/article/247904/berita/semasa/jumlah-mangsa-banjir-johor-meningkat-kepada-33149-pagi-ini","https://www.thestar.com.my/news/nation/2024/10/14/johor-faces-severe-flood-risk-at-745-sites","https://www.bernama.com/bm/news.php?id=1859866"],"verdict":"CONFIRMED"}],"statewide":[{"issue_bm":"Sejak JS-SEZ dimeterai Januari 2025, harga apartmen servis di Johor Bahru melonjak 20.4% dalam setahun — anak muda Puteri Wangsa bergaji ringgit terpaksa bersaing dengan permintaan pelabur rentas sempadan untuk rumah pertama, sampai calon PH sendiri mengaku harga rumah tinggi untuk golongan muda adalah masalah utama di sini.","issue_en":"Since the JS-SEZ was signed in January 2025, Johor Bahru serviced-apartment prices have jumped 20.4% in a single year — young Puteri Wangsa workers earning ringgit are competing with cross-border investor demand for their first home, and even the PH candidate admits high house prices for the young are a top problem here.","receipt_bm":"17 Julai 2025: FMT lapor data JLL Malaysia — harga apartmen servis Johor Bahru naik 20.4% setahun pada S2 2025 (teres dua tingkat +8.6%), didorong momentum JS-SEZ; 30 Jun 2026: Bernama lapor harga rumah tinggi bagi golongan muda antara isu utama di Puteri Wangsa.","receipt_en":"17 July 2025: FMT, citing JLL Malaysia — Johor Bahru serviced-apartment prices up 20.4% year-on-year in Q2 2025 (double-storey terraces +8.6%), driven by JS-SEZ momentum; 30 June 2026: Bernama reports high house prices for young people among the top issues in Puteri Wangsa.","sources":["https://www.freemalaysiatoday.com/category/nation/2025/07/17/johor-bahru-property-prices-surge-on-js-sez-momentum","https://www.bernama.com/radio/news.php?id=2574713","https://iqiglobal.com/blog/johor-real-estate/"],"verdict":"PARTLY_CONFIRMED"},{"issue_bm":"Setahun selepas MB umum pelabur JS-SEZ setuju bayar \"gaji premium\" RM3,500, calon PH Puteri Wangsa sendiri mengaku remaja kita masih cicir sekolah untuk kerja gig atau kerja kasar di Singapura sebab bayarannya tiga kali ganda — dan dia akui kerajaan negeri sahaja tak mampu selesaikannya.","issue_en":"A year after the MB announced JS-SEZ investors agreed to pay RM3,500 \"premium salaries\", PH's own Puteri Wangsa candidate admits local teens are still dropping out of school for gig work or manual jobs in Singapore paying triple — and that the state government alone cannot fix it.","receipt_bm":"30 Jun 2026 (Bernama): Maszlee sebut keciciran pelajaran remaja di Puteri Wangsa dan gaji kerja kasar Singapura \"tiga kali ganda\"; 20 Mei 2025 (Sinar Harian): Onn Hafiz umum pelabur JS-SEZ setuju gaji minimum RM3,500 (diploma) / RM4,000+ (ijazah), bersyarat produktiviti dan kemahiran.","receipt_en":"30 June 2026 (Bernama): Maszlee names teen school dropout in Puteri Wangsa and \"triple\" Singapore manual-job wages; 20 May 2025 (Sinar Harian): Onn Hafiz announced JS-SEZ investors agreed to RM3,500 (diploma) / RM4,000+ (degree) minimum salaries, conditional on productivity and skills.","sources":["https://www.bernama.com/radio/news.php?id=2574713","https://www.sinarharian.com.my/article/729512/edisi/johor/pelabur-js-sez-setuju-tawar-gaji-premium-ndash-onn-hafiz","https://www.thestar.com.my/news/nation/2020/01/02/maszlee-quits-as-education-minister"],"verdict":"PARTLY_CONFIRMED"},{"issue_bm":"Anak muda Muar terpaksa lari ke Singapura sebab gaji di sana tiga kali ganda — 16,930 rakyat Malaysia melepaskan kewarganegaraan pada 2024 sahaja dan lebih 350,000 berulang-alik setiap hari — sedangkan \"gaji premium dari RM3,500\" yang dijanjikan MB semuanya dalam zon JS-SEZ di selatan Johor, 150km dari Muar.","issue_en":"Muar's young people are forced out to Singapore because pay there is roughly triple — 16,930 Malaysians gave up their citizenship in 2024 alone and over 350,000 commute daily — while the MB's promised \"premium salaries from RM3,500\" all sit in JS-SEZ zones in southern Johor, 150km from Muar.","receipt_bm":"Jawapan Parlimen KDN, 11 Ogos 2025: 97,318 rakyat Malaysia jadi warga Singapura 2015–Jun 2025, rekod 16,930 pada 2024; lebih 350,000 ulang-alik ke Singapura setiap hari; janji MB \"gaji premium dari RM3,500\" (Mei 2025) terikat pada 9 zon utama JS-SEZ — kesemuanya di selatan Johor, tiada satu pun di Muar.","receipt_en":"Home Ministry parliamentary reply, 11 Aug 2025: 97,318 Malaysians renounced citizenship for Singapore's between 2015 and June 2025, a record 16,930 in 2024; over 350,000 commute to Singapore daily; the MB's May 2025 \"premium salaries from RM3,500\" pledge is tied to the nine JS-SEZ flagship zones — all in southern Johor, none in Muar.","sources":["https://www.thestar.com.my/news/nation/2025/08/11/nearly-100000-malaysians-renounce-citizenship-for-singapore-in-a-decade-says-home-ministry","https://www.thestar.com.my/metro/metro-news/2025/07/17/johor-stems-brain-drain-to-singapore","https://amro-asia.org/johor-gets-second-chance-at-economic-take-off","https://www.freemalaysiatoday.com/category/nation/2022/05/01/pay-two-thirds-of-singapore-wages-to-keep-locals-home-says-dap-man/"],"verdict":"CONFIRMED"}],"updated":"2026-07-03"}}